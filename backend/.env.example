DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/ai_recruit
REDIS_URL=redis://localhost:6379/0

# 平台默认模型配置（用于"平台托管"模式，以及 BYOK 用户未配置时的回退）
GEMINI_API_KEY=your-api-key-here
GEMINI_BASE_URL=https://www.sophnet.com/api/open-apis/v1
GEMINI_MODEL=gemini-3-pro-preview

# 用户 API Key 加密密钥（Fernet 对称加密，32 字节 base64 编码）
# 生成方式：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 注意：此密钥一旦设定不可更改，否则已存储的用户 API Key 将无法解密
ENCRYPTION_KEY=generate-with-python-cryptography-fernet-generate-key

# JWT 认证密钥（用于签发 access_token 和 refresh_token）
JWT_SECRET_KEY=your-jwt-secret-key
